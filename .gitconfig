[user]
	name = Mathieu Méa
	email = mathieu.mea@gmail.com
[color]
	ui = auto
[push]
	default = simple
	autoSetupRemote = true
[core]
	editor = gedit -s
[alias]
	add-all-sm-add = "!f() { git submodule foreach \" git add . \" ; git add . ; }; f"
	addne = "!f() { git add --intent-to-add $1; git add --edit $1; }; f"
	addAllSb = "!f() { git add .; git sb; }; f"
	backupCheckout = "!f() { cp $1 $1.back; git checkout $1; }; f"
	backupMeld = "!f() { meld $1 $1.back; }; f"
	backupRm = "!f() { rm $1.back; }; f"
	branch-sm = "!f() { git branch; git submodule foreach git branch; }; f"
	branch-current-sm = "!f() { git branch --show-current; git submodule foreach git branch --show-current; }; f"
	brancha-sm = "!f() { git branch -a; git submodule foreach git branch -a; }; f"
	branchvv = "!f() { git branch -vv; }; f"
	checkoutBranch = "!f() { git checkout -b $1; }; f"
	checkoutBranchAndPush = "!f() { git checkoutBranch $1; git push; }; f"
	cleanDemoSb = "!f() { git clean --dry-run -d ; git sb ; }; f"
	cleanForceAllSb = "!f() { git clean --force -d ; git sb; }; f"
	clipboardXClip = "!f() { xclip -out -sel clip; }; f"
	cloneMtMmathieum = "!f() { git clone --branch mmathieum "git@github.com:mtransitapps/$1.git" ; }; f"
	cloneBranchMmathieum = "!f() { git clone --branch mmathieum "$1" ; }; f"
	commitAllowEmpty = "!f() { git commit --allow-empty -m \"$1\"; }; f"
	commitq = "!f() { git commit -q -m \"$1\"; }; f"
	commitqq = "!f() { git commit -q -m \"$1\" > /dev/null; }; f"
	commit-sm = "!f() { echo \"Entering '$(basename $PWD)'\"; git commit -m \"$1\" || echo 'NO CHANGE' ; git submodule foreach \" git commit -m '$1' || echo 'NO CHANGE' \" ; }; f"
	commit-sm-add = "!f() { git submodule foreach \" git commitqq '$1' || echo 'NO CHANGE' \" ; echo \"Entering '$(basename $PWD)'\"; git add . ; git commitqq \"$1\" || echo \"NO CHANGE\" ; }; f"
	commitAndPush = "!f() { git commit -m \"$1\"; git push; }; f"
	commitClipboardXClip = "!f() { git commit -m \"$(xclip -out -sel clip)\"; }; f"
	commitAndPushClipboardXClip = "!f() { git commit -m \"$(xclip -out -sel clip)\"; git push; }; f"
	commitClipboardXClipDryRun = "!f() { git commit --dry-run -m \"$(xclip -out -sel clip)\"; git push --dry-run; }; f"
	commitTodayUpdate-sm-add = "!f() { git commit-sm-add \"$(date +'%-B %-d update')\" ; }; f"
	commitTodayUpdateAndPush = "!f() { git commit -m \"$(date +'%-B %-d update')\"; git push; }; f"
	copyLastCommitXClip = "!f() { git log -1 --no-merges --pretty=%B | xclip -sel clip; echo \"Clipboard: '$(xclip -out -sel clip)'.\"; }; f"
	createNewBranchAndPush = "!f() { git checkout -b $1; git push -u origin $1; }; f"
	deleteBranchAndPush = "!f() { git branch --delete $1; git push origin --delete $1; }; f"
	diffu0 = "!f() { git diff -U0 $1; }; f"
	diffu0-sm = "!f() { git diffu0 $1; git submodule foreach git diffu0 $1; }; f"
	diff-sm = "!f() { git diff; git submodule foreach git diff; }; f"
	diffstaged = "!f() { git diff --staged; }; f"
	diffstaged-sm = "!f() { git diffstaged; git submodule foreach git diffstaged; }; f"
	diffstat = "!f() { git diff --stat; }; f"
	diffstat-sm = "!f() { git diff --stat; git submodule foreach git diff --stat; }; f"
	diffword = "!f() { git diff --word-diff; }; f"
	diffword-sm = "!f() { git diff --word-diff; git submodule foreach git diff --word-diff; }; f"
	fetchp = "!f() { git fetch -p; }; f"
	fetch-sm = "!f() { git fetch; git submodule foreach git fetch; }; f"
	forcePushCurrentBranch = "!git push --force origin \"$(git rev-parse --abbrev-ref HEAD)\""
	gc-sm = "!f() { git gc; git submodule foreach git gc; }; f"
	gh-PrComment = "!f() { gh pr comment --body \"$@\" ; }; f"
	gh-PrComment-GeminiReview = "!f() { git gh-prcomment \"/gemini review\" ; }; f"
	gh-PrCreate-Me-Draft-Auto = "!f() { gh pr create --draft --assignee \"@me\" --fill-first ; }; f"
	#
	lod = log --pretty=format:'%C(auto)%h%d%Creset %C(cyan)[%cI]%Creset %s' # %C(green)%cn%Creset # --graph
	lod1 = "!f() { git lod -n 1 $@ ; }; f"
	lod-sm = "!f() { echo \"Entering '$(basename $PWD)'\"; git lod1; git submodule foreach git lod1; }; f"
	lod7 = "!f() { git lod -n 7 $@ ; }; f"
	lod7-sm = "!f() { echo \"Entering '$(basename $PWD)'\"; git lod7 $@; git submodule foreach git lod7 $@; }; f"
	lod1d = "!f() { git lod --since=\"1 day ago\"  $@ ; }; f"
	lod1d-sm = "!f() { echo \"Entering '$(basename $PWD)'\"; git lod1d $@; git submodule foreach git lod1d $@; }; f"
	lod1w = "!f() { git lod --since=\"1 week ago\"  $@ ; }; f"
	lod1w-sm = "!f() { echo \"Entering '$(basename $PWD)'\"; git lod1w $@; git submodule foreach git lod1w $@; }; f"
	lod1m = "!f() { git lod --since=\"1 month ago\"  $@ ; }; f"
	lod1m-sm = "!f() { echo \"Entering '$(basename $PWD)'\"; git lod1m $@; git submodule foreach git lod1m $@; }; f"
	lod33 = "!f() { git lod -n 33  $@ ; }; f"
	lod33-sm = "!f() { echo \"Entering '$(basename $PWD)'\"; git lod33 $@; git submodule foreach git lod33 $@; }; f"
	lod77 = "!f() { git lod -n 77  $@ ; }; f"
	lod77-sm = "!f() { echo \"Entering '$(basename $PWD)'\"; git lod77 $@; git submodule foreach git lod77 $@; }; f"
	lodLastMonth = "!f() { git lod --since=\"last month\"  $@ ; }; f"
	lodLastMonth-sm = "!f() { echo \"Entering '$(basename $PWD)'\"; git lodLastMonth $@; git submodule foreach git lodLastMonth $@; }; f"
	lodLastMonthMine-sm = "!f() { echo \"Entering '$(basename $PWD)'\"; git lod  --since=\"last month\" --author=\"Mathieu Méa\" $@; git submodule foreach git lod  --since=\"last month\" --author=\"Mathieu Méa\" $@; }; f"
	lodSinceLastRelease = "!f() { git lod $(git describe --tags --abbrev=0)..HEAD $@ ; }; f"
	lod111 = "!f() { git lod -n 111 ; }; f"
	#
	logOneLine = "!f() { git log -n 1 --oneline $@ ; }; f"
	logOneLine-sm = "!f() { echo \"Entering '$(basename $PWD)'\"; git logOneLine $@; git submodule foreach git logOneLine $@; }; f"
	logOneLine7 = "!f() { git log -n 7 --oneline $@ ; }; f"
	logOneLine7-sm = "!f() { echo \"Entering '$(basename $PWD)'\"; git logOneLine7 $@; git submodule foreach git logOneLine7 $@; }; f"
	logOneLine1d = "!f() { git log --since=\"1 day ago\" --oneline $@ ; }; f"
	logOneLine1d-sm = "!f() { echo \"Entering '$(basename $PWD)'\"; git logOneLine1d $@; git submodule foreach git logOneLine1d $@; }; f"
	logOneLine1w = "!f() { git log --since=\"1 week ago\" --oneline $@ ; }; f"
	logOneLine1w-sm = "!f() { echo \"Entering '$(basename $PWD)'\"; git logOneLine1w $@; git submodule foreach git logOneLine1w $@; }; f"
	logOneLine1m = "!f() { git log --since=\"1 month ago\" --oneline $@ ; }; f"
	logOneLine1m-sm = "!f() { echo \"Entering '$(basename $PWD)'\"; git logOneLine1m $@; git submodule foreach git logOneLine1m $@; }; f"
	logOneLine33 = "!f() { git log -n 33 --oneline $@ ; }; f"
	logOneLine33-sm = "!f() { echo \"Entering '$(basename $PWD)'\"; git logOneLine33 $@; git submodule foreach git logOneLine33 $@; }; f"
	logOneLine77 = "!f() { git log -n 77 --oneline $@ ; }; f"
	logOneLine77-sm = "!f() { echo \"Entering '$(basename $PWD)'\"; git logOneLine77 $@; git submodule foreach git logOneLine77 $@; }; f"
	logOneLineLastMonth = "!f() { git log --since=\"last month\" --oneline $@ ; }; f"
	logOneLineLastMonth-sm = "!f() { echo \"Entering '$(basename $PWD)'\"; git logOneLineLastMonth $@; git submodule foreach git logOneLineLastMonth $@; }; f"
	logOneLineLastMonthMine-sm = "!f() { echo \"Entering '$(basename $PWD)'\"; git log --oneline --since=\"last month\" --author=\"Mathieu Méa\" $@; git submodule foreach git log --oneline --since=\"last month\" --author=\"Mathieu Méa\" $@; }; f"
	logOneLineSinceLastRelease = "!f() { git log --oneline $(git describe --tags --abbrev=0)..HEAD $@ ; }; f"
	logOneLine111 = "!f() { git log -n 111 --oneline; }; f"
	#
	mergeFastForwardOnlyAndPush = "!f() { git merge --ff-only --no-commit $1; git push; }; f"
	pull-sm = "!f() { echo \"Entering '$(basename $PWD)'\"; git pull --verbose; git submodule foreach git pull --verbose; }; f"
	pullsb = "!f() { git pull; git sb; }; f"
	pullsb-sm = "!f() { echo \"Entering '$(basename $PWD)'\"; git pull; git submodule foreach git pull; git sb-sm; }; f"
	push-sm = "!f() { git submodule foreach git push; echo \"Entering '$(basename $PWD)'\"; git push; }; f"
	pushorigin = "!f() { git push origin $1; }; f"
	pushorigin-sm = "!f() { echo \"Entering '$(basename $PWD)'\"; git push origin $1; git submodule foreach git push origin $1; }; f"
	revertHead = "!f() { git revert HEAD; }; f" # revert last commit
	remotePruneOrigin = "!f() { git remote prune origin; }; f"
	remotePruneOrigin-sm = "!f() { echo \"Entering '$(basename $PWD)'\"; git remotePruneOrigin; git submodule foreach git remotePruneOrigin; }; f"
	restoreSb = "!f() { git restore $1 ; git sb; }; f"
	restoreAllSb = "!f() { git restoreSb . ; }; f"
	restoreCleanForceAllSb = "!f() { git restore .; git clean -f ; git sb; }; f"
	restoreStagedSb = "!f() { git restore --staged $1 ; git sb; }; f"
	restoreStagedAllSb = "!f() { git restoreStagedSb . ; }; f"
	resetLocalCommit = "!f() { git reset HEAD^; }; f"
	rmdeleted = "!f() { git rm $(git ls-files --deleted); }; f"
	showStaged = "!f() { git show :$1 ; }; f"
	stashincludeuntracked = "!f() { git stash --include-untracked; }; f"
	stashincludeuntracked-sm = "!f() { git stash --include-untracked; git submodule foreach \"git stash --include-untracked\"; }; f"
	stashlist = "!f() { git stash list; }; f"
	stashlist-sm = "!f() { git stash list; git submodule foreach \"git stash list\"; }; f"
	stashpop = "!f() { git stash pop; }; f"
	stashpop-sm = "!f() { git stashpop; git submodule foreach \"git stashpop || echo 'NO STASH' \"; }; f"
	stashpullpop = "!f() { git stash; git pull; git stash pop; }; f"
	stashpullpopreset = "!f() { git stash; git pull; git stash pop; git reset; }; f"
	sb = "!f() { git status -sb; }; f"
	sbStagedOnly = "!f() { git branch --show-current ; git diff --name-status --cached; }; f"
	sbStagedOnly-sm = "!f() { echo \"Entering '$(basename $PWD)'\"; git sbStagedOnly; git submodule foreach git sbStagedOnly;  }; f"
	sbNotStagedOnly = "!f() { git branch --show-current ; git diff --name-status ; }; f"
	sbNotStagedOnly-sm = "!f() { echo \"Entering '$(basename $PWD)'\"; git sbNotStagedOnly; git submodule foreach git sbNotStagedOnly;  }; f"
	sback = "!f() { git sb -- '*.back'; }; f"
	sb-sm = "!f() { echo \"Entering '$(basename $PWD)'\"; git sb; git submodule foreach git sb; }; f"
	sback-sm = "!f() { git sb -- '*.back'; git submodule foreach git sb -- '*.back'; }; f"
	switch-sm = "!f() { echo \"Entering '$(basename $PWD)'\"; git switch $1; git submodule foreach git switch $1; }; f"
	switch-sm-master = "!f() { git switch-sm master; }; f"
	switch-sm-only = "!f() { git submodule foreach git switch $1; }; f"
	switch-sm-only-master = "!f() { git switch-sm-only master; }; f"
[gui]
	tabsize = 4
[pull]
	rebase = false
[filter "lfs"]
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
